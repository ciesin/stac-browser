  "properties": {
    "title": "CODATA Catalog of Roads Data Sets, Version 1",
    "description": "The CODATA Catalog of Roads Data Sets, Version 1 contains 367 entries describing national-level road network data sets for 147 countries and four entries describing global data sets. It was produced by the Columbia University Center for International Earth Science Information Network (CIESIN) under the oversight of the CODATA Global Roads Data Development Working Group, and as a contribution to the development of the Global Roads Open Access Data Set (gROADS).",
    "purpose": "To provide documentation on roads data sets that are potential candidates for inclusion in the Global Roads Open Access Data Set (gROADS), and which may be useful to others searching for data on road infrastructure.",
    "doi": "https://doi.org/10.7927/H4X63JTX",
