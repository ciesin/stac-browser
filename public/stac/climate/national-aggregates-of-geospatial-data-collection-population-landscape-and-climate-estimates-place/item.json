  "properties": {
    "title": "National Aggregates of Geospatial Data Collection: Population, Landscape, And Climate Estimates (PLACE)",
    "description": "The National Aggregates of Geospatial Data Collection: Population, Landscape, And Climate Estimates (PLACE) data set contains estimates of national-level aggregations of territorial extent and population size by biome, climate zone, coastal proximity, elevation and slope, a compendium of nearly 300 variables for 222 countries. This data set is produced by the Columbia University Center for International Earth Science Information Network (CIESIN).",
    "purpose": "To provide tabular data on environmental conditions (elevations, climate, coastal) in which people reside.",
