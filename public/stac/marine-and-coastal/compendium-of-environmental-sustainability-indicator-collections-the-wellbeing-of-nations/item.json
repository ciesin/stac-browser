  "properties": {
    "title": "Compendium of Environmental Sustainability Indicator Collections: The Wellbeing of Nations",
    "description": "The Wellbeing of Nations portion of the Compendium of Environmental Sustainability Indicator Collections contains a subset of 123 variables assembled from the Wellbeing of Nations, which assesses human and ecosystem wellbeing for 183 countries. The variables selected include both raw data and processed indicators and indices created by the report's author, Robert Prescott-Allen. The data are distributed by the Columbia University Center for International Earth Science Information Network (CIESIN).",
    "purpose": "To provide data that address the key issues of sustainability by combining indicators of human wellbeing with those of environmental sustainability to generate a more comprehensive picture of the state of the world.",
    "authors": "Prescott-Allen, R",
    "publishers": "Island Press",
    "place": "Washington, DC",
    "version": "1.00",
    "doi": "https://doi.org/10.7927/H4MS3QNT",
    "citation": "Prescott-Allen, R. 2001. Compendium of Environmental Sustainability Indicator Collections: The Wellbeing of Nations. Washington, DC: Island Press. https://doi.org/10.7927/H4MS3QNT. Accessed [DAY MONTH YEAR].",
